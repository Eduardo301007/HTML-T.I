        {
            margin-bottom: 20px;
            background: linear-gradient(to right, rgb(191, 0, 255), rgb(0, 157, 255));
            color: white;
            border-radius: 7px;
            padding: 20px 30px;
            box-shadow: 10px 10px 15px rgba(128, 128, 128, 0.687);
